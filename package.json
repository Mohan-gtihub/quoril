{
  "name": "quoril",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Desktop productivity and focus tracking application",
  "author": "Mohan Kilari",
  "main": "dist-electron/index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "vite",
    "build": "tsc && vite build && electron-builder",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dist": "npm run build",
    "dist:win": "npm run build -- --win",
    "dist:mac": "npm run build -- --mac",
    "dist:linux": "npm run build -- --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@supabase/supabase-js": "^2.38.5",
    "@tanstack/react-query": "^5.17.0",
    "@tiptap/extension-color": "^3.22.4",
    "@tiptap/extension-font-family": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-horizontal-rule": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-subscript": "^3.22.4",
    "@tiptap/extension-superscript": "^3.22.4",
    "@tiptap/extension-table": "^3.22.4",
    "@tiptap/extension-table-cell": "^3.22.4",
    "@tiptap/extension-table-header": "^3.22.4",
    "@tiptap/extension-table-row": "^3.22.4",
    "@tiptap/extension-task-item": "^3.22.4",
    "@tiptap/extension-task-list": "^3.22.4",
    "@tiptap/extension-text-align": "^3.22.4",
    "@tiptap/extension-text-style": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@types/howler": "^2.2.12",
    "@types/rbush": "^4.0.0",
    "@xyflow/react": "^12.10.2",
    "active-win": "^8.2.1",
    "better-sqlite3": "^9.4.3",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "density-clustering": "^1.3.0",
    "dotenv": "^17.2.4",
    "framer-motion": "^12.34.2",
    "howler": "^2.2.4",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.303.0",
    "mitt": "^3.0.1",
    "rbush": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.21.0",
    "react-tooltip": "^5.30.0",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.2.0",
    "tiptap-extension-font-size": "^1.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.quoril.app",
    "productName": "Quoril",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/active-win/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quoril"
    },
    "mac": {
      "icon": "public/icon.png",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "protocols": [
      {
        "name": "Quoril URL Scheme",
        "schemes": [
          "quoril"
        ]
      }
    ]
  }
}
